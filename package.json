{
  "name": "krasnaya-ploshchad",
  "private": true,
  "version": "1.6.5",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/tere-project",
    "build": "npm run build --workspace=apps/tere-project",
    "lint": "npm run lint --workspace=apps/tere-project",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "mcp:build": "npm run build --workspace=apps/mcp-server",
    "mcp:start": "npm run start --workspace=apps/mcp-server",
    "mcp:release": "npm run release --workspace=apps/mcp-server",
    "mcp:release:minor": "npm run release:minor --workspace=apps/mcp-server",
    "mcp:release:major": "npm run release:major --workspace=apps/mcp-server"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "npm@10.9.2"
}
